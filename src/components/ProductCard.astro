---
import type { Lang } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import type { Product } from '@/data/types';
import { leagueForTeam } from '@/data/seed';

interface Props {
  product: Product;
  lang: Lang;
  /** When true and product has `nameClean`, render the cleaner name (used on /order). */
  useCleanName?: boolean;
}

const { product, lang, useCleanName = false } = Astro.props;

const displayName = (useCleanName && product.nameClean) ? product.nameClean[lang] : product.name[lang];

const href = `/${lang}/jersey/${product.slug}`;

const availLabel =
  product.availability === 'in_stock'  ? t('product.in_stock', lang)
  : product.availability === 'pre_order' ? t('product.pre_order', lang)
  : t('product.sold_out', lang);

const availClass =
  product.availability === 'in_stock'  ? 'bg-brand-gold text-brand-darker'
  : product.availability === 'pre_order' ? 'border border-brand-gold text-brand-gold'
  : 'bg-brand-line text-brand-muted';

const searchText = [
  product.team,
  product.name[lang],
  product.season,
  product.kitType,
  product.version,
  product.audience,
].join(' ');

const hasMultipleImages = product.images.length > 1;
---
<a
  href={href}
  data-audience={product.audience}
  data-season={product.season}
  data-league={leagueForTeam(product.team)}
  data-search-text={searchText}
  data-card-gallery
  class="product-card group block bg-brand-darker border border-brand-line rounded-2xl overflow-hidden hover:border-brand-gold transition-colors"
>
  <div class="aspect-[4/5] bg-brand-line relative overflow-hidden">
    {product.images.map((src, i) => (
      <img
        src={src}
        alt={`${displayName} — ${i === 0 ? (lang === 'pt' ? 'frente' : 'front') : (lang === 'pt' ? 'costas' : 'back')}`}
        loading={i === 0 ? 'eager' : 'lazy'}
        data-card-img={i}
        class:list={['card-img', { 'card-img-active': i === 0 }]}
        onerror="this.style.background='linear-gradient(135deg,#1F1F1F,#0A0A0A)';this.removeAttribute('src');"
      />
    ))}

    {/* Single primary badge — priority: clearance > new > kids. */}
    <div class="absolute top-3 left-3 z-10">
      {product.isClearance ? (
        <span class="text-[10px] uppercase tracking-widest bg-red-600 text-white font-bold px-2 py-1 rounded">
          {lang === 'pt' ? 'Promoção' : 'Sale'}
        </span>
      ) : product.isNew ? (
        <span class="text-[10px] uppercase tracking-widest bg-brand-gold text-brand-darker font-bold px-2 py-1 rounded">
          {t('product.new', lang)}
        </span>
      ) : product.audience === 'kids' ? (
        <span class="text-[10px] uppercase tracking-widest bg-brand-light text-brand-darker font-bold px-2 py-1 rounded">
          {t('product.kids', lang)}
        </span>
      ) : null}
    </div>

    {hasMultipleImages && (
      <>
        <button type="button" class="card-arrow card-prev" data-card-action="prev" aria-label="Previous image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button type="button" class="card-arrow card-next" data-card-action="next" aria-label="Next image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
        <div class="card-dots" aria-hidden="true">
          {product.images.map((_, i) => (
            <button
              type="button"
              data-card-dot={i}
              class:list={['card-dot', { active: i === 0 }]}
              aria-label={`Show image ${i + 1}`}
            ></button>
          ))}
        </div>
      </>
    )}
  </div>

  <div class="p-4">
    <div class="text-xs text-brand-muted">{product.team}</div>
    <h3 class="font-semibold mt-1 group-hover:text-brand-gold transition-colors">{displayName}</h3>
    <div class="mt-2 text-[11px] text-brand-muted">
      <span class={product.availability === 'in_stock' ? 'text-brand-gold font-semibold' : ''}>
        {availLabel}
      </span>
      <span class="opacity-60"> · {product.shippingDays} {t('product.shipping.days', lang)}</span>
    </div>
    <div class="mt-3 flex items-baseline justify-between">
      <span class="text-lg font-bold">{product.price.toFixed(2)}€</span>
      {product.personalization && product.personalization.price === 0 && (
        <span class="text-[10px] text-brand-gold/70 uppercase tracking-wider">
          {lang === 'pt' ? '✦ Pers. grátis' : '✦ Free pers.'}
        </span>
      )}
    </div>
  </div>
</a>

<style>
  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 250ms ease, transform 600ms ease;
  }
  .card-img-active {
    opacity: 1;
  }
  .product-card:hover .card-img-active {
    transform: scale(1.04);
  }

  .card-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: rgba(10, 10, 10, 0.65);
    color: var(--color-brand-light);
    border: 1px solid var(--color-brand-line);
    backdrop-filter: blur(4px);
    cursor: pointer;
    padding: 0;
    opacity: 0.85;
    transition: background-color 150ms, color 150ms, opacity 150ms;
  }
  .card-arrow:hover {
    background: var(--color-brand-gold);
    color: var(--color-brand-darker);
    opacity: 1;
  }
  .card-arrow svg {
    width: 0.95rem;
    height: 0.95rem;
  }
  .card-prev { left: 0.5rem; }
  .card-next { right: 0.5rem; }

  .card-dots {
    position: absolute;
    bottom: 0.65rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.35rem;
    background: rgba(10, 10, 10, 0.6);
    padding: 0.3rem 0.55rem;
    border-radius: 9999px;
    backdrop-filter: blur(4px);
    z-index: 5;
  }
  .card-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.5);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 150ms;
  }
  .card-dot:hover { background: rgba(255, 255, 255, 0.8); }
  .card-dot.active { background: var(--color-brand-gold); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-card-gallery]').forEach((card) => {
    const imgs = card.querySelectorAll<HTMLImageElement>('[data-card-img]');
    const dots = card.querySelectorAll<HTMLButtonElement>('[data-card-dot]');
    const total = imgs.length;
    if (total <= 1) return;

    let current = 0;
    function show(next: number) {
      current = ((next % total) + total) % total;
      imgs.forEach((img, i) => img.classList.toggle('card-img-active', i === current));
      dots.forEach((dot, i) => dot.classList.toggle('active', i === current));
    }

    function bind(selector: string, handler: (e: Event) => void) {
      card.querySelectorAll(selector).forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          handler(e);
        });
      });
    }

    bind('[data-card-action="prev"]', () => show(current - 1));
    bind('[data-card-action="next"]', () => show(current + 1));
    dots.forEach((dot, i) => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        show(i);
      });
    });
  });
</script>
