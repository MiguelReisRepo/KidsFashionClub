---
import type { Lang } from '@/lib/i18n';
import { t } from '@/lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---
<div class="trust-strip border-b border-brand-line bg-brand-darker/40 backdrop-blur-sm">
  <ul class="max-w-6xl mx-auto px-4 py-2.5 flex flex-wrap items-center justify-center gap-x-6 gap-y-1.5 text-[11px] text-brand-muted">
    <li class="inline-flex items-center gap-1.5">
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 text-brand-gold/80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="6" width="20" height="12" rx="2"/>
        <path d="M2 10h20"/>
      </svg>
      <span>{t('trust.payment', lang)}</span>
    </li>
    <li class="inline-flex items-center gap-1.5">
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 text-brand-gold/80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 3h15v13H1zM16 8h4l3 3v5h-7"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>{t('trust.shipping', lang)}</span>
    </li>
    <li class="inline-flex items-center gap-1.5">
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 text-brand-gold/80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
        <path d="M21 3v5h-5"/>
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
        <path d="M8 16H3v5"/>
      </svg>
      <span>{t('trust.returns', lang)}</span>
    </li>
    <li class="inline-flex items-center gap-1.5">
      <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 text-brand-gold/80" fill="currentColor" aria-hidden="true">
        <path d="M20.52 3.48A11.86 11.86 0 0 0 12.04 0C5.48 0 .15 5.32.15 11.88c0 2.1.55 4.14 1.6 5.94L0 24l6.34-1.66a11.85 11.85 0 0 0 5.7 1.45h.01c6.56 0 11.89-5.32 11.89-11.88 0-3.18-1.24-6.16-3.42-8.43Z"/>
      </svg>
      <span>{t('trust.whatsapp', lang)}</span>
    </li>
  </ul>
</div>
