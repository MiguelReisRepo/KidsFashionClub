---
import type { Lang } from '@/lib/i18n';
import { t } from '@/lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---
<details class="size-guide group mt-2">
  <summary class="cursor-pointer list-none inline-flex items-center gap-1.5 text-xs text-brand-gold hover:text-brand-gold-soft transition-colors">
    <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 9h18M9 21V9"/>
    </svg>
    <span class="underline">{t('size.guide.label', lang)}</span>
    <span class="transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
  </summary>
  <div class="mt-3 bg-brand-darker border border-brand-line rounded-2xl p-3">
    <p class="text-xs text-brand-muted mb-2">{t('size.guide.help', lang)}</p>
    <img src="/sizes-kids.png" alt={t('size.guide.label', lang)} class="w-full max-w-md mx-auto rounded-lg" loading="lazy" />
  </div>
</details>
