---
import type { Lang } from '@/lib/i18n';
import { t, ROUTES } from '@/lib/i18n';
import { plainLink } from '@/lib/whatsapp';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const r = ROUTES[lang];
const ig = import.meta.env.PUBLIC_INSTAGRAM_URL;
const wa = plainLink(lang);
---
<footer class="border-t border-brand-line bg-brand-darker mt-20">
  <div class="max-w-6xl mx-auto px-4 py-10 grid gap-8 md:grid-cols-4 text-sm">
    <div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-gold text-brand-darker font-extrabold">K</span>
        <span class="font-extrabold">Kids Fan Club</span>
      </div>
      <p class="mt-3 text-brand-muted">{t('footer.tagline', lang)}</p>
    </div>

    <div>
      <h4 class="font-semibold mb-3">{t('nav.home', lang)}</h4>
      <ul class="space-y-2 text-brand-muted">
        <li><a href={r.stock}    class="hover:text-brand-gold">{t('nav.stock', lang)}</a></li>
        <li><a href={r.order}    class="hover:text-brand-gold">{t('nav.order', lang)}</a></li>
        <li><a href={r.how}      class="hover:text-brand-gold">{t('nav.how', lang)}</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-semibold mb-3">{t('nav.about', lang)}</h4>
      <ul class="space-y-2 text-brand-muted">
        <li><a href={r.about}    class="hover:text-brand-gold">{t('nav.about', lang)}</a></li>
        <li><a href={r.faq}      class="hover:text-brand-gold">{t('nav.faq', lang)}</a></li>
        <li><a href={r.shipping} class="hover:text-brand-gold">{t('nav.shipping', lang)}</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-semibold mb-3">Contacto</h4>
      <ul class="space-y-2 text-brand-muted">
        <li><a href={wa} target="_blank" rel="noopener" class="hover:text-brand-gold">WhatsApp</a></li>
        {ig && <li><a href={ig} target="_blank" rel="noopener" class="hover:text-brand-gold">Instagram</a></li>}
      </ul>
    </div>
  </div>
  <div class="border-t border-brand-line">
    <div class="max-w-6xl mx-auto px-4 py-4 text-xs text-brand-muted flex justify-between">
      <span>© {new Date().getFullYear()} Kids Fan Club — {t('footer.rights', lang)}.</span>
      <span>v0.1</span>
    </div>
  </div>
</footer>
