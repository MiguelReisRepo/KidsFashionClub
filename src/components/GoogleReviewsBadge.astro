---
import type { Lang } from '@/lib/i18n';
import { t } from '@/lib/i18n';

interface Props {
  lang: Lang;
  /** "compact" → footer/inline pill. "full" → homepage hero card. */
  variant?: 'compact' | 'full';
}

const { lang, variant = 'full' } = Astro.props;

const writeUrl   = import.meta.env.PUBLIC_GOOGLE_REVIEWS_URL;
const profileUrl = import.meta.env.PUBLIC_GOOGLE_PROFILE_URL;

// Render nothing if we have neither URL — the badge degrades gracefully.
const hasAnyUrl = !!(writeUrl || profileUrl);
---
{hasAnyUrl && (
  variant === 'compact' ? (
    <a
      href={profileUrl || writeUrl}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 text-xs text-brand-muted hover:text-brand-gold transition-colors"
    >
      <svg viewBox="0 0 24 24" class="w-4 h-4" aria-hidden="true">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/>
        <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83Z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.46 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38Z"/>
      </svg>
      <span>{t('reviews.read', lang)}</span>
    </a>
  ) : (
    <div class="bg-brand-darker border border-brand-line rounded-3xl p-8 md:p-10 grid md:grid-cols-[auto_1fr_auto] gap-6 items-center">
      <div class="flex items-center gap-3">
        <svg viewBox="0 0 24 24" class="w-10 h-10" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/>
          <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83Z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.46 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38Z"/>
        </svg>
        <div>
          <div class="flex items-center gap-1 text-brand-gold text-lg">
            <span aria-hidden="true">★★★★★</span>
          </div>
          <div class="text-xs text-brand-muted mt-0.5">{t('reviews.sub', lang)}</div>
        </div>
      </div>

      <div>
        <h3 class="text-2xl font-extrabold">{t('reviews.title', lang)}</h3>
        <p class="text-brand-muted text-sm mt-1">{t('reviews.firstCustomer', lang)}</p>
      </div>

      <div class="flex flex-wrap gap-2 md:justify-end">
        {profileUrl && (
          <a href={profileUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 border border-brand-line text-brand-light text-sm font-semibold rounded-full px-4 py-2 hover:border-brand-gold hover:text-brand-gold transition-colors">
            {t('reviews.read', lang)}
          </a>
        )}
        {writeUrl && (
          <a href={writeUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-brand-gold text-brand-darker text-sm font-semibold rounded-full px-4 py-2 hover:bg-brand-gold-soft transition-colors">
            {t('reviews.write', lang)} →
          </a>
        )}
      </div>
    </div>
  )
)}
