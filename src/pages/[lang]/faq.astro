---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LANGS, type Lang, t } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const seo = buildPageSeo({
  lang,
  path: `/${lang}/faq`,
  title: t('nav.faq', lang),
  description: lang === 'pt' ? 'Perguntas frequentes sobre tamanhos, encomendas, pagamentos e envios.' : 'FAQ about sizes, orders, payments, and shipping.',
});

const faqs = {
  pt: [
    { q: 'As camisolas são oficiais?', a: 'Vendemos versões adepto (réplicas não oficiais). É indicado em cada produto.' },
    { q: 'Como sei o meu tamanho?', a: 'Cada marca corta diferente — pede-nos a tabela de medidas via WhatsApp antes de confirmar.' },
    { q: 'Como pago?', a: 'MB WAY ou transferência bancária. Cartão e Multibanco em breve via IfthenPay.' },
    { q: 'Quanto demora a chegar?', a: 'Em stock: 24-48h. Por encomenda: 2-3 semanas em média.' },
    { q: 'Posso devolver?', a: 'Sim, dentro de 14 dias após a entrega, desde que a camisola esteja por usar com etiquetas.' },
  ],
  en: [
    { q: 'Are the jerseys official?', a: 'We sell fan versions (unofficial replicas). It’s noted on each product page.' },
    { q: 'How do I know my size?', a: 'Each brand fits differently — ask us for the size chart on WhatsApp before confirming.' },
    { q: 'How do I pay?', a: 'MB WAY or bank transfer. Card and Multibanco coming soon via IfthenPay.' },
    { q: 'How long until it arrives?', a: 'In stock: 24-48h. Pre-order: 2-3 weeks on average.' },
    { q: 'Can I return it?', a: 'Yes, within 14 days of delivery, if unworn and with tags.' },
  ],
}[lang];
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold">{t('nav.faq', lang)}</h1>
    <div class="mt-10 divide-y divide-brand-line">
      {faqs.map((f) => (
        <details class="py-5 group">
          <summary class="cursor-pointer list-none flex justify-between items-start gap-4 font-semibold">
            <span>{f.q}</span>
            <span class="text-brand-gold transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 text-brand-muted">{f.a}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
