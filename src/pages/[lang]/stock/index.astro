---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import AudienceFilter from '@/components/AudienceFilter.astro';
import SeasonFilter from '@/components/SeasonFilter.astro';
import SearchBar from '@/components/SearchBar.astro';
import { LANGS, t, type Lang } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';
import { inStockProducts, uniqueSeasons } from '@/data/seed';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const products = inStockProducts();
const seasons = uniqueSeasons();

const seo = buildPageSeo({
  lang,
  path: `/${lang}/stock`,
  title: t('cat.stock.title', lang),
  description: lang === 'pt'
    ? 'Camisolas de futebol disponíveis em stock — adultos e kids. Envio em 24-48h.'
    : 'Football jerseys in stock — adults and kids. Ships in 24-48h.',
});
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>
  <section class="catalog max-w-6xl mx-auto px-4 py-12">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-4xl font-extrabold">{t('cat.stock.title', lang)}</h1>
        <p class="text-brand-muted mt-2">{t('home.stock.sub', lang)}</p>
      </div>
      <div class="flex flex-wrap items-center gap-3 w-full sm:w-auto">
        <SearchBar lang={lang} />
        <AudienceFilter lang={lang} group="stock" />
        {seasons.length > 1 && <SeasonFilter lang={lang} group="stock" seasons={seasons} />}
      </div>
    </div>

    {products.length === 0
      ? <p class="mt-12 text-brand-muted">—</p>
      : (
        <div class="mt-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {products.map((p) => <ProductCard product={p} lang={lang} />)}
        </div>
      )
    }
  </section>
</BaseLayout>

<style is:global>
  /* Audience hide rules — global because product-card lives in a child component scope. */
  .catalog:has(input[id^="aud-"][id$="-kids"]:checked)  .product-card[data-audience="adult"] { display: none; }
  .catalog:has(input[id^="aud-"][id$="-adult"]:checked) .product-card[data-audience="kids"]  { display: none; }
</style>
