---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LANGS, type Lang, t } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const seo = buildPageSeo({
  lang,
  path: `/${lang}/about`,
  title: t('nav.about', lang),
  description: lang === 'pt'
    ? 'Quem somos e por que vendemos camisolas de futebol.'
    : 'Who we are and why we sell football jerseys.',
});

const copy = {
  pt: {
    h1: 'Sobre Nós',
    p1: 'A Kids Fashion Club nasceu de uma paixão pelo futebol e pela ideia de que a camisola é mais do que um produto — é uma forma de pertencer.',
    p2: 'Curamos um catálogo de camisolas em stock e, para tudo o resto, encontramos por ti. Falamos com o cliente como se fala com um amigo: por WhatsApp, sem fricções.',
  },
  en: {
    h1: 'About Us',
    p1: 'Kids Fashion Club was born from a love of football and the idea that a jersey is more than a product — it’s a way of belonging.',
    p2: 'We curate a catalog of in-stock jerseys and source the rest for you. We talk to customers the way you talk to a friend: on WhatsApp, no friction.',
  },
}[lang];
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold">{copy.h1}</h1>
    <p class="mt-6 text-brand-muted leading-relaxed">{copy.p1}</p>
    <p class="mt-4 text-brand-muted leading-relaxed">{copy.p2}</p>
  </section>
</BaseLayout>
