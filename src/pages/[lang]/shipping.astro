---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LANGS, type Lang, t } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const seo = buildPageSeo({
  lang,
  path: `/${lang}/shipping`,
  title: t('nav.shipping', lang),
  description: lang === 'pt' ? 'Política de envios e devoluções.' : 'Shipping and returns policy.',
});

const copy = {
  pt: {
    h1: 'Envios e Devoluções',
    sections: [
      { h: 'Envios', p: 'Em stock: enviamos em 24-48h via CTT Expresso. Por encomenda: 2-3 semanas em média.' },
      { h: 'Custos', p: 'Portugal Continental: 4,50€. Ilhas: 7€. Grátis em compras acima de 80€.' },
      { h: 'Devoluções', p: 'Tens 14 dias para devolver. A camisola tem de estar por usar e com etiquetas. Os custos de devolução são do cliente.' },
      { h: 'Trocas', p: 'Trocas de tamanho gratuitas para Portugal Continental, sujeitas a stock.' },
    ],
  },
  en: {
    h1: 'Shipping & Returns',
    sections: [
      { h: 'Shipping', p: 'In stock: ships in 24-48h via CTT Expresso. Pre-order: 2-3 weeks on average.' },
      { h: 'Costs', p: 'Mainland Portugal: €4.50. Islands: €7. Free over €80.' },
      { h: 'Returns', p: 'You have 14 days to return. Jersey must be unworn and tagged. Return shipping is on the customer.' },
      { h: 'Exchanges', p: 'Free size exchanges within mainland Portugal, subject to stock.' },
    ],
  },
}[lang];
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold">{copy.h1}</h1>
    <div class="mt-10 space-y-8">
      {copy.sections.map((s) => (
        <div>
          <h2 class="text-xl font-bold text-brand-gold">{s.h}</h2>
          <p class="mt-2 text-brand-muted">{s.p}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
