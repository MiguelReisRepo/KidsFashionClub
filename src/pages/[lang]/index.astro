---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import AudienceFilter from '@/components/AudienceFilter.astro';
import SeasonFilter from '@/components/SeasonFilter.astro';
import LeagueFilter from '@/components/LeagueFilter.astro';
import SearchBar from '@/components/SearchBar.astro';
import EmptyState from '@/components/EmptyState.astro';
import GoogleReviewsBadge from '@/components/GoogleReviewsBadge.astro';
import { LANGS, t, type Lang, ROUTES } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';
import { customOrderLink } from '@/lib/whatsapp';
import { inStockProducts, allProductsSorted, uniqueSeasons, uniqueLeagues } from '@/data/seed';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const r = ROUTES[lang];

const stock   = inStockProducts().slice(0, 4);
const all     = allProductsSorted();
const seasons = uniqueSeasons();
const leagues = uniqueLeagues();
const wa      = customOrderLink(lang);

const seo = buildPageSeo({
  lang,
  path: `/${lang}`,
  title: lang === 'pt' ? 'Camisolas de Futebol — Stock e Encomenda' : 'Football Jerseys — In Stock and Pre-Order',
  description: lang === 'pt'
    ? 'Compra camisolas de futebol em stock ou por encomenda. Envio rápido em Portugal. Encomenda direta via WhatsApp.'
    : 'Buy football jerseys in stock or pre-order. Fast shipping across Portugal. Order direct via WhatsApp.',
});
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-brand-line">
    <div class="absolute inset-0 opacity-30 pointer-events-none" style="background: radial-gradient(60% 60% at 70% 30%, rgba(232,185,35,0.25), transparent 70%), radial-gradient(40% 40% at 20% 80%, rgba(232,185,35,0.15), transparent 70%);"></div>
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-28 relative">
      <p class="text-xs uppercase tracking-[0.3em] text-brand-gold">{t('home.hero.kicker', lang)}</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-extrabold tracking-tight max-w-3xl">{t('home.hero.title', lang)}</h1>
      <p class="mt-6 text-lg text-brand-muted max-w-2xl">{t('home.hero.subtitle', lang)}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={r.stock} class="inline-flex items-center gap-2 bg-brand-gold text-brand-darker font-semibold rounded-full px-6 py-3 hover:bg-brand-gold-soft transition-colors">
          {t('home.hero.cta', lang)} →
        </a>
        <WhatsAppButton href={wa} label={t('home.hero.cta2', lang)} variant="outline" />
      </div>
    </div>
  </section>

  <!-- Em Stock -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl font-extrabold">{t('home.stock.title', lang)}</h2>
        <p class="text-brand-muted text-sm mt-1">{t('home.stock.sub', lang)}</p>
      </div>
      <a href={r.stock} class="text-sm text-brand-gold hover:underline">{t('cta.viewAll', lang)} →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {stock.map((p) => <ProductCard product={p} lang={lang} />)}
    </div>
  </section>

  <!-- Catálogo Completo -->
  <section class="catalog max-w-6xl mx-auto px-4 py-16 border-t border-brand-line">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-8">
      <div>
        <h2 class="text-3xl font-extrabold">{t('home.all.title', lang)}</h2>
        <p class="text-brand-muted text-sm mt-1">{t('home.all.sub', lang)} — {all.length}</p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <SearchBar lang={lang} />
        <AudienceFilter lang={lang} group="home" />
        {leagues.length > 1 && <LeagueFilter lang={lang} group="home" leagues={leagues} />}
        {seasons.length > 1 && <SeasonFilter lang={lang} group="home" seasons={seasons} />}
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {all.map((p) => <ProductCard product={p} lang={lang} />)}
    </div>
    <EmptyState lang={lang} />
  </section>

  <style is:global>
    .catalog:has(input[id^="aud-"][id$="-kids"]:checked)  .product-card[data-audience="adult"] { display: none; }
    .catalog:has(input[id^="aud-"][id$="-adult"]:checked) .product-card[data-audience="kids"]  { display: none; }
  </style>

  <!-- Reviews Google -->
  <section class="max-w-6xl mx-auto px-4 py-16 border-t border-brand-line">
    <GoogleReviewsBadge lang={lang} variant="full" />
  </section>

  <!-- Encomendar específica -->
  <section class="max-w-6xl mx-auto px-4 py-16 border-t border-brand-line">
    <div class="bg-brand-darker border border-brand-line rounded-3xl p-8 md:p-12 grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="text-3xl font-extrabold">{t('home.order.title', lang)}</h2>
        <p class="mt-3 text-brand-muted">{t('home.order.body', lang)}</p>
      </div>
      <div class="flex md:justify-end">
        <WhatsAppButton href={wa} label={t('product.ask', lang)} />
      </div>
    </div>
  </section>

  <!-- Como funciona -->
  <section class="max-w-6xl mx-auto px-4 py-16 border-t border-brand-line">
    <h2 class="text-3xl font-extrabold mb-10">{t('home.how.title', lang)}</h2>
    <ol class="grid md:grid-cols-5 gap-4">
      {[t('home.how.s1', lang), t('home.how.s2', lang), t('home.how.s3', lang), t('home.how.s4', lang), t('home.how.s5', lang)].map((step, i) => (
        <li class="bg-brand-darker border border-brand-line rounded-2xl p-5">
          <div class="text-brand-gold font-extrabold text-2xl">0{i + 1}</div>
          <p class="mt-3 text-sm">{step}</p>
        </li>
      ))}
    </ol>
  </section>

</BaseLayout>
