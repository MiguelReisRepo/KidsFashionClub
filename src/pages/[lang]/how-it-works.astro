---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LANGS, type Lang, t } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };

const seo = buildPageSeo({
  lang,
  path: `/${lang}/how-it-works`,
  title: t('nav.how', lang),
  description: lang === 'pt' ? 'Como funciona o processo de encomenda.' : 'How the ordering process works.',
});

const steps = [
  t('home.how.s1', lang),
  t('home.how.s2', lang),
  t('home.how.s3', lang),
  t('home.how.s4', lang),
  t('home.how.s5', lang),
];
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-extrabold">{t('nav.how', lang)}</h1>
    <ol class="mt-10 space-y-4">
      {steps.map((s, i) => (
        <li class="flex gap-4 items-start bg-brand-darker border border-brand-line rounded-2xl p-5">
          <span class="text-brand-gold font-extrabold text-2xl">0{i + 1}</span>
          <p class="pt-1">{s}</p>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
