---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import AudienceFilter from '@/components/AudienceFilter.astro';
import SearchBar from '@/components/SearchBar.astro';
import { LANGS, t, type Lang } from '@/lib/i18n';
import { buildPageSeo } from '@/lib/seo';
import { customOrderLink } from '@/lib/whatsapp';
import { preOrderProducts } from '@/data/seed';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const products = preOrderProducts();
const wa = customOrderLink(lang);

const seo = buildPageSeo({
  lang,
  path: `/${lang}/order`,
  title: t('cat.order.title', lang),
  description: lang === 'pt'
    ? 'Camisolas por encomenda — adultos e kids. Diz-nos o que queres e tratamos da disponibilidade.'
    : 'Pre-order jerseys — adults and kids. Tell us what you want and we’ll source it.',
});
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical}>
  <section class="catalog max-w-6xl mx-auto px-4 py-12">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-4xl font-extrabold">{t('cat.order.title', lang)}</h1>
        <p class="text-brand-muted mt-2">
          {lang === 'pt' ? 'Prazo típico: 2-3 semanas' : 'Typical lead time: 2-3 weeks'}
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3 w-full sm:w-auto">
        <SearchBar lang={lang} />
        <AudienceFilter lang={lang} group="order" />
        <WhatsAppButton href={wa} label={lang === 'pt' ? 'Pedir específica' : 'Request specific'} variant="outline" />
      </div>
    </div>

    {products.length === 0
      ? <p class="mt-12 text-brand-muted">—</p>
      : (
        <div class="mt-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {products.map((p) => <ProductCard product={p} lang={lang} />)}
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .catalog:has(input[id$="-kids"]:checked)  .product-card[data-audience="adult"] { display: none; }
  .catalog:has(input[id$="-adult"]:checked) .product-card[data-audience="kids"]  { display: none; }
</style>
