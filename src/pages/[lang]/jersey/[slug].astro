---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import ProductGallery from '@/components/ProductGallery.astro';
import { LANGS, t, type Lang } from '@/lib/i18n';
import { buildPageSeo, productJsonLd } from '@/lib/seo';
import { buyLink, askLink } from '@/lib/whatsapp';
import { products } from '@/data/seed';

export function getStaticPaths() {
  return LANGS.flatMap((lang) =>
    products.map((p) => ({ params: { lang, slug: p.slug }, props: { product: p } }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { product } = Astro.props as { product: typeof products[number] };

const isPreOrder = product.availability === 'pre_order';
const wa = isPreOrder ? askLink(product, lang) : buyLink(product, lang);
const ig = import.meta.env.PUBLIC_INSTAGRAM_URL;

const path = `/${lang}/jersey/${slug}`;
const seo = buildPageSeo({
  lang,
  path,
  title: product.name[lang],
  description: product.description[lang],
  ogImage: product.images[0],
});

const jsonLd = productJsonLd(product, lang, path);

const availLabel =
  product.availability === 'in_stock'  ? t('product.in_stock', lang)
  : product.availability === 'pre_order' ? t('product.pre_order', lang)
  : t('product.sold_out', lang);
---
<BaseLayout lang={lang} title={seo.title} description={seo.description} canonical={seo.canonical} ogImage={seo.ogImage} jsonLd={jsonLd}>
  <section class="max-w-6xl mx-auto px-4 py-12 grid md:grid-cols-2 gap-10">

    <ProductGallery images={product.images} alt={product.name[lang]} />

    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-brand-gold">{product.team} · {product.season}</p>
      <h1 class="mt-3 text-4xl font-extrabold">{product.name[lang]}</h1>

      <div class="mt-4 flex items-center gap-3">
        <span class="text-3xl font-bold">{product.price.toFixed(2)}€</span>
        <span class={`text-xs uppercase tracking-widest font-bold px-2 py-1 rounded ${
          product.availability === 'in_stock' ? 'bg-brand-gold text-brand-darker'
          : product.availability === 'pre_order' ? 'border border-brand-gold text-brand-gold'
          : 'bg-brand-line text-brand-muted'
        }`}>{availLabel}</span>
      </div>

      <p class="mt-6 text-brand-muted leading-relaxed">{product.description[lang]}</p>

      <div class="mt-8 border-t border-brand-line pt-6 space-y-4">
        <div>
          <div class="text-sm text-brand-muted">{t('product.sizes', lang)}</div>
          <div class="mt-2 flex flex-wrap gap-2">
            {product.sizes.map((s) => (
              <span class="border border-brand-line text-sm font-semibold px-3 py-1.5 rounded-full">{s}</span>
            ))}
          </div>
        </div>
        <div>
          <div class="text-sm text-brand-muted">{t('product.shipping', lang)}</div>
          <div class="mt-1 font-semibold">
            {product.shippingDays} {t('product.shipping.days', lang)}
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <WhatsAppButton href={wa} label={isPreOrder ? t('product.ask', lang) : t('product.buy', lang)} />
        {ig && (
          <a href={ig} target="_blank" rel="noopener" class="inline-flex items-center gap-2 border border-brand-line text-brand-light font-semibold rounded-full px-5 py-3 hover:border-brand-gold hover:text-brand-gold transition-colors text-sm">
            Instagram
          </a>
        )}
      </div>
    </div>

  </section>
</BaseLayout>
